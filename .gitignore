# =========================================================================
# .gitignore - K6MetricsCloud
# =========================================================================

# ---------------------------------------------------------------------------
# Credentials / secrets — NEVER commit these
# ---------------------------------------------------------------------------
set-env.cmd
set-env.sh
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Temporary files from curl/testing
# ---------------------------------------------------------------------------
cookies.txt

# ---------------------------------------------------------------------------
# k6 output files
# ---------------------------------------------------------------------------
*.json.gz
k6-results/
summary.json

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Node (in case anyone installs tooling locally)
# ---------------------------------------------------------------------------
node_modules/
package-lock.json
